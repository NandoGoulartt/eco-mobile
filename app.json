{
  "expo": {
    "name": "Gestão de Caçambas",
    "slug": "cacambas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cacambas.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.cacambas.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Este app precisa de acesso à localização para registrar entregas e retiradas de caçambas."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Este app precisa de acesso à câmera para tirar fotos das caçambas."
        }
      ],
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "cacambas",
    "extra": {
      "eas": {
        "projectId": "e564923e-2ab3-4e82-8b63-5d41a7309bf3"
      }
    }
  }
}
